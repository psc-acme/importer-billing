{
    "name": "psc-acme/importer-billing",
    "description": "Package importer-billing for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ImporterBilling\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "league/flysystem": "^3.0",
        "symfony/validator": "^7.0",
        "nesbot/carbon": "^2.72",
        "brick/math": "^0.12"
    },
    "require-dev": {
        "rector/rector": "^1.0",
        "phpunit/phpunit": "^10.5"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}